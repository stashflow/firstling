NEXT_PUBLIC_SITE_URL=
# Vercel Neon integration usually injects one or more of these.
DATABASE_URL=
POSTGRES_URL=
POSTGRES_PRISMA_URL=

RESEND_API_KEY=
WEBHOOK_SECRET=

# Stripe. Vercel Marketplace Stripe can provision STRIPE_SECRET_KEY.
# Price IDs are optional; if unset, Checkout creates the plan prices inline.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_PRICE_ID=
STRIPE_BASIC_PRICE_ID=
STRIPE_GROWTH_PRICE_ID=

# Optional generic SMS relay. Leave unset to skip SMS without failing webhooks.
SMS_PROVIDER_API_KEY=
SMS_FROM_NUMBER=
SMS_PROVIDER_URL=

# Optional. If set, /admin/demo-calls requires HTTP Basic auth.
ADMIN_BASIC_USER=
ADMIN_BASIC_PASSWORD=
